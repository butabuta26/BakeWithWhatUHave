<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pantry Baking - Account</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="icon" type="image/x-icon" href="/images/favicon-pie.png">
    <link rel="stylesheet" href="/styles/style.css">
</head>
<body>
    <header class="sticky-top">
        <%- include('partials/navbar') %>
    </header>
    
    <section class="profile-section py-5">
        <div class="container">
            <div class="profile-card">
                <div class="row align-items-center g-4 w-100">
                    <div class="col-12 col-md-auto text-center">
                        <img src="/images/default-avatar.png"
                             class="profile-image"
                             alt="Profile picture">
                    </div>
            
                    <div class="col">
                        <h1><%= user.name %></h1>
                        <p class="mb-4">
                            <%= user.email %>
                        </p>
            
                        <div class="profile-stats">
                            <div class="stat">
                                <h2>4</h2>
                                <span>Liked Recipes</span>
                            </div>
            
                            <div class="stat">
                                <h2>4</h2>
                                <span>Rated Recipes</span>
                            </div>
            
                            <div class="stat">
                                <h2>4.3 ★</h2>
                                <span>Average Rating</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Liked Recipes -->
    <section class="liked-section py-5">
        <div class="container">
            <div class="section-heading">
                <h2>❤️ Liked Recipes</h2>
                <p>Your favorite recipes all in one place.</p>
            </div>

            <div id="liked-container" class="row g-4">
                <!-- Recipe cards will go here from js -->
            </div>
        </div>
    </section>

    <!-- Rated Recipes -->
    <section class="rated-section py-5">
        <div class="container">
            <div class="section-heading">
                <h2>⭐ Rated Recipes</h2>
                <p>Recipes you've left a rating on.</p>
            </div>

            <div id="rated-container" class="row g-4">
                <!-- Recipe cards will go here from js -->
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>

    <script type="module" src="/scripts/recipe.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>